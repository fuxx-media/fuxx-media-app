# Copy only the variable names into your environment and replace every placeholder.
# Do not commit a populated .env file.
POSTGRES_USER=<set-locally>
POSTGRES_PASSWORD=<set-locally>
POSTGRES_DB=<set-locally>
MINIO_ROOT_USER=<set-locally>
MINIO_ROOT_PASSWORD=<set-locally>
NEXT_PUBLIC_API_URL=http://localhost:8000
MEDIAOS_LOG_LEVEL=INFO
MEDIAOS_FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MEDIAOS_PRIVATE_BUCKET=mediaos-private
MEDIAOS_UPLOAD_MAX_BYTES=10485760
MEDIAOS_SESSION_TTL_SECONDS=28800
# Local HTTP only. Production HTTPS must set this to true.
MEDIAOS_COOKIE_SECURE=false
